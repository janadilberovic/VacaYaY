# EditorConfig for VacaYAY — https://editorconfig.org
# Root config; stops EditorConfig from looking in parent directories.
root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,jsonc,yml,yaml,csproj,props,targets}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.cs]
indent_size = 4

# --- C# code style (enforced by `dotnet format`) ---

# Namespaces: file-scoped (matches existing code, e.g. AuthController.cs).
csharp_style_namespace_declarations = file_scoped:warning

# using directives: System.* first, outside the namespace.
dotnet_sort_system_directives_first = true
csharp_using_directive_placement = outside_namespace:warning

# Prefer var when the type is apparent (matches existing style).
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_for_built_in_types = false:suggestion

# Expression-bodied members / modern C# preferences (light-touch, suggestions only).
csharp_prefer_braces = true:suggestion
csharp_new_line_before_open_brace = all
dotnet_style_require_accessibility_modifiers = for_non_interface_members:warning

# Trailing newline / whitespace already covered by [*] above.
