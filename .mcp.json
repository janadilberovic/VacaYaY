{
  "mcpServers": {
    "vacayay-mysql": {
      "command": "npx",
      "args": ["-y", "@benborla29/mcp-server-mysql"],
      "env": {
        "MYSQL_HOST": "${VACAYAY_DB_HOST:-127.0.0.1}",
        "MYSQL_PORT": "${VACAYAY_DB_PORT:-3306}",
        "MYSQL_USER": "${VACAYAY_DB_USER}",
        "MYSQL_PASS": "${VACAYAY_DB_PASS}",
        "MYSQL_DB": "${VACAYAY_DB_NAME:-vacayay}",
        "ALLOW_INSERT_OPERATION": "false",
        "ALLOW_UPDATE_OPERATION": "false",
        "ALLOW_DELETE_OPERATION": "false"
      }
    }
  }
}
